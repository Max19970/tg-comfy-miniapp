{
  "name": "tg-comfy-miniapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend start",
    "set-webhook": "node scripts/set-webhook.js",
    "delete-webhook": "node scripts/delete-webhook.js",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "check-setup": "node scripts/check-setup.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
